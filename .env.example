# Required
TWELVE_DATA_API_KEY=replace_me
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Protects the public Render test endpoints.
API_AUTH_TOKEN=replace_with_a_long_random_string

# Defaults are suitable for the first MVP.
ACCOUNT_CURRENCY=USD
RISK_PER_TRADE_USD=400
SYMBOLS=EUR/USD,GBP/USD,USD/JPY,AUD/USD,USD/CAD,GBP/JPY
SCAN_OUTPUT_SIZE=500
SCAN_GRACE_SECONDS=20
ENABLE_WEBSOCKET=true
SEND_STARTUP_MESSAGE=true
STATE_DB_PATH=./smc_state.sqlite3
LOG_LEVEL=INFO
